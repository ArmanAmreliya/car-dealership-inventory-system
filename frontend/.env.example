# ─────────────────────────────────────────────────────────────────────────────
# DealerFlow Frontend — Environment Variables
#
# Copy this file to .env and fill in the values for your environment.
#
#   cp .env.example .env
#
# All variables MUST be prefixed with VITE_ to be exposed to the browser bundle.
# Never commit .env to version control — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────────────────────

# Base URL of the DealerFlow backend API.
# Include the /api path segment; do NOT include a trailing slash.
# Development default points to the local backend dev server.
VITE_API_BASE_URL=http://localhost:3000/api

# ── Application ───────────────────────────────────────────────────────────────

# Display name shown in the browser tab and any branding elements.
VITE_APP_TITLE=DealerFlow

# ── Feature flags (optional) ──────────────────────────────────────────────────

# Set to "true" to enable analytics / telemetry integration.
# Leave empty or set to "false" to disable (default).
VITE_ENABLE_ANALYTICS=false
